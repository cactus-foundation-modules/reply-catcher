{
  "name": "contact-form-reply-catcher",
  "version": "0.1.7",
  "tablePrefix": "rc_",
  "description": "Polls the contact-form admin's real mailbox and threads submitter replies (and personally-sent replies) back into the Cactus contact-form inbox.",
  "requiresModules": [
    { "name": "contact-form", "minVersion": "0.1.0" }
  ],
  "permissions": [
    "replycatcher.manage"
  ],
  "navEntries": [],
  "settingsTabs": [
    { "id": "contact-form-reply-catcher", "label": "Reply Catcher", "permission": "replycatcher.manage", "import": "./components/SettingsTab", "component": "ReplyCatcherSettingsTab" }
  ],
  "extensionPoints": [
    { "point": "contact-form.inbox-actions", "id": "reply-catcher-fetch-latest", "permission": "replycatcher.manage", "import": "./components/FetchLatestRepliesButton", "component": "FetchLatestRepliesButton" },
    { "point": "contact-form.inbox-actions", "id": "reply-catcher-caught-replies-link", "permission": "replycatcher.manage", "import": "./components/CaughtRepliesButton", "component": "CaughtRepliesButton" },
    { "point": "contact-form.thread-messages", "id": "reply-catcher-messages", "permission": "replycatcher.manage", "import": "./lib/thread-messages", "component": "getCaughtReplyThreadMessages" }
  ],
  "requiredEnvVars": [
    { "name": "ENCRYPTION_KEY", "required": true },
    { "name": "CRON_SECRET", "required": false }
  ],
  "cookieCategories": [],
  "teardown": ["rc_mailbox_config", "rc_processed_messages", "rc_caught_replies"],
  "cronJobs": [
    { "path": "/api/m/contact-form-reply-catcher/cron/poll", "schedule": "0 6 * * *" }
  ]
}
